# =============================================
# Copia este archivo como .env y completalo
# NUNCA subas .env al repositorio
# =============================================

# Telegram Bot (para recibir notificaciones)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Credenciales del Consulado (opcionales - no se usan en modo automático)
CONSULADO_IDU=
CONSULADO_PASS=

# Opciones de ejecución
HEADLESS=false          # false = ve el navegador, true = sin ventana
MONITOR_ALL=false       # true = monitorear todos los trámites del site_map.json
# TARGET_IDS=4,9       # solo monitorear trámites con estos IDs (separados por coma)
# MODE=discovery       # para mapear el sitio y generar site_map.json

